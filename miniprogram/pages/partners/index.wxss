.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.top-app-bar {
  background-color: #ffffff;
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 0 16px;
  height: 56px;
  position: sticky;
  top: 0;
  z-index: 50;
  border-bottom: 1px solid #e4e2e1;
}

.back-btn, .add-btn {
  padding: 8px;
  margin: 0 -8px;
}

.back-btn .icon, .add-btn .icon {
  font-size: 24px;
}

.back-btn .icon {
  color: #414755;
}

.add-btn .icon {
  color: #0057c2;
}

.page-title {
  font-size: 18px;
  font-weight: 600;
  color: #1b1c1c;
}

.icon {
  font-size: 24px;
}

.main-content {
  flex: 1;
  padding: 16px;
  padding-bottom: 24px;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.search-bar {
  position: relative;
  width: 100%;
}

.search-icon {
  position: absolute;
  left: 12px;
  top: 50%;
  transform: translateY(-50%);
  color: #727786;
  font-size: 20px;
}

.search-input {
  width: 100%;
  height: 40px;
  padding-left: 40px;
  padding-right: 40px;
  background-color: #ffffff;
  border: 1px solid #c1c6d7;
  border-radius: 8px;
  font-size: 14px;
  color: #1b1c1c;
}

.search-input::placeholder {
  color: #727786;
}

.filter-btn {
  position: absolute;
  right: 8px;
  top: 50%;
  transform: translateY(-50%);
  padding: 4px;
}

.filter-btn .icon {
  color: #727786;
  font-size: 20px;
}

.filter-btn:active {
  color: #0057c2;
}

.partner-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.partner-card {
  background-color: #ffffff;
  border-radius: 12px;
  padding: 16px;
  border: 1px solid #f0f0f0;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
  position: relative;
  overflow: hidden;
}

.card-bg {
  position: absolute;
  top: 0;
  right: 0;
  width: 64px;
  height: 64px;
  background-color: rgba(0, 87, 194, 0.05);
  border-radius: 0 0 0 100%;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 8px;
}

.partner-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.avatar-placeholder {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background-color: #f6f3f2;
  border: 1px solid rgba(193, 198, 215, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 18px;
  font-weight: 600;
  color: #0057c2;
}

.avatar-image {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 1px solid rgba(193, 198, 215, 0.3);
  flex-shrink: 0;
}

.partner-details {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.partner-name {
  font-size: 16px;
  font-weight: 500;
  color: #1b1c1c;
}

.partner-id {
  font-size: 12px;
  color: #5d5f5f;
}

.status-tag {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 8px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
  border: 1px solid;
}

.status-tag.active {
  background-color: #dcfce7;
  color: #166534;
  border-color: #bbf7d0;
}

.status-tag.active .status-dot {
  background-color: #22c55e;
}

.status-tag.pending {
  background-color: #ffedd5;
  color: #c2410c;
  border-color: #fed7aa;
}

.status-tag.pending .status-dot {
  background-color: #fb923c;
}

.status-tag.disabled {
  background-color: #f3f4f6;
  color: #6b7280;
  border-color: #e5e7eb;
}

.status-tag.disabled .status-dot {
  background-color: #9ca3af;
}

.status-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
}

.card-body {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 4px;
  padding-left: 56px;
  margin-bottom: 12px;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 4px;
}

.small-icon {
  font-size: 16px;
  color: #727786;
}

.info-text {
  font-size: 14px;
  color: #414755;
}

.card-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  padding-top: 12px;
  border-top: 1px solid #e4e2e1;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
}

.action-btn.edit {
  background-color: #ffffff;
  border: 1px solid #0057c2;
  color: #0057c2;
}

.action-btn.edit:active {
  background-color: #0057c2;
  color: #ffffff;
}

.action-btn.delete {
  background-color: #ffffff;
  color: #ba1a1a;
}

.action-btn.delete:active {
  background-color: rgba(186, 26, 26, 0.1);
}

.action-btn .icon {
  font-size: 16px;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  backdrop-filter: blur(2px);
}

.modal-content {
  background-color: #ffffff;
  width: 300px;
  border-radius: 12px;
  padding: 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
}

.modal-icon {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background-color: rgba(186, 26, 26, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
}

.modal-icon .icon {
  font-size: 24px;
}

.modal-title {
  font-size: 18px;
  font-weight: 600;
  color: #1b1c1c;
  margin-bottom: 8px;
}

.modal-message {
  font-size: 14px;
  color: #414755;
  text-align: center;
  margin-bottom: 24px;
  line-height: 1.6;
}

.modal-message .highlight {
  font-weight: 700;
  color: #1b1c1c;
}

.modal-actions {
  display: flex;
  width: 100%;
  gap: 16px;
}

.modal-btn {
  flex: 1;
  padding: 10px;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 600;
}

.modal-btn.cancel {
  background-color: #f0eded;
  color: #414755;
}

.modal-btn.confirm {
  background-color: #ba1a1a;
  color: #ffffff;
}

.modal-btn.confirm:active {
  opacity: 0.8;
}
